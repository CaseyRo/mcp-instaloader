# MCP Server Configuration
MCP_PORT=3336

# Optional: Path to Instagram session cookie file for private content access
# COOKIE_FILE=/root/.config/instaloader/session-<username>

# Keycloak JWT Authentication (optional — omit to run without auth)
KEYCLOAK_ISSUER=https://auth.cdit-works.de/realms/cdit-mcp
KEYCLOAK_AUDIENCE=mcp-instaloader
MCP_API_KEY=
